# ──────────────────────────────────────────────
# CocoFresh Backend — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Database (Supabase PostgreSQL) ────────────
# Pooler URL (use for app queries - port 6543)
DATABASE_URL="postgresql://postgres.YOURREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct URL (used by Prisma for migrations - port 5432)
DIRECT_URL="postgresql://postgres:PASSWORD@db.YOURREF.supabase.co:5432/postgres"

# ── App ───────────────────────────────────────
NODE_ENV=production
PORT=8080
TZ=Asia/Kolkata

# ── Security ──────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING

# ── CORS ──────────────────────────────────────
# Your DigitalOcean frontend URL (from App Platform)
CORS_ORIGIN=https://YOUR-APP.ondigitalocean.app
